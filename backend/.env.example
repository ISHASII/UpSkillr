# App
PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/upskillr

# JWT
JWT_SECRET=dev_jwt_secret_change_me
JWT_EXPIRES_IN=1d

# SMTP (Forgot Password OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_email@example.com
SMTP_PASS=your_smtp_app_password_or_token
SMTP_FROM=UpSkillr <your_smtp_email@example.com>

# OTP Settings
OTP_EXPIRES_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
