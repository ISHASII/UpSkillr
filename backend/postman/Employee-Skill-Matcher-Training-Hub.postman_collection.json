    {
      "name": "Training Flow v2",
      "item": [
        {
          "name": "HR - Create Module (Goals + Link/File)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{hrToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "judul",
                  "value": "Modul React Lanjutan",
                  "type": "text"
                },
                {
                  "key": "deskripsi",
                  "value": "Pendalaman React",
                  "type": "text"
                },
                {
                  "key": "goalsModule",
                  "value": "Menyelesaikan project",
                  "type": "text"
                },
                {
                  "key": "targetSkills",
                  "value": "[\"{{skillId}}\"]",
                  "type": "text"
                },
                {
                  "key": "linkMateri",
                  "value": "https://example.com/materi-react",
                  "type": "text"
                },
                {
                  "key": "materiFiles",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/modules",
              "host": ["{{baseUrl}}"],
              "path": ["api", "modules"]
            }
          }
        },
        {
          "name": "Karyawan - Enroll Module",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{karyawanToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"module_id\": \"{{moduleId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "logs"]
            }
          }
        },
        {
          "name": "Karyawan - Submit Task (Link/File)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{karyawanToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "submissionLink",
                  "value": "https://drive.google.com/my-task",
                  "type": "text"
                },
                {
                  "key": "submissionFiles",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/logs/{{logId}}/submission",
              "host": ["{{baseUrl}}"],
              "path": ["api", "logs", "{{logId}}", "submission"]
            }
          }
        },
        {
          "name": "HR - Validate Submission Approve",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{hrToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"approve\",\n  \"feedback\": \"Sesuai requirement, selamat lulus\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/logs/{{logId}}/validation",
              "host": ["{{baseUrl}}"],
              "path": ["api", "logs", "{{logId}}", "validation"]
            }
          }
        },
        {
          "name": "HR - Validate Submission Reject",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{hrToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"reject\",\n  \"feedback\": \"Perbaiki sesuai catatan\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/logs/{{logId}}/validation",
              "host": ["{{baseUrl}}"],
              "path": ["api", "logs", "{{logId}}", "validation"]
            }
          }
        },
        {
          "name": "HR - List Participants By Module",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{hrToken}}",
