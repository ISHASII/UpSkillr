            "body": {
              "mode": "raw",
              "raw": "{\n  \"nama\": \"Admin HR\",\n  \"email\": \"{{hrEmail}}\",\n  \"password\": \"{{hrPassword}}\",\n  \"role\": \"HRD\",\n  \"divisi\": \"Human Resource\",\n  \"skills\": [\"Leadership\", \"Recruitment\"]\n}"
