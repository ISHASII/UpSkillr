    {
      "name": "Auth",
      "item": [
        {
          "name": "Register HR",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nama\": \"Admin HR\",\n  \"email\": \"hr@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"HR\",\n  \"divisi\": \"Human Resource\",\n  \"skills\": [\"Leadership\", \"Recruitment\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Register Karyawan",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nama\": \"Karyawan Satu\",\n  \"email\": \"karyawan@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"Karyawan\",\n  \"divisi\": \"Engineering\",\n  \"skills\": [\"Node.js\", \"MongoDB\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login HR",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.token) {",
                  "  pm.collectionVariables.set('hrToken', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"hr@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login Karyawan",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.token) {",
                  "  pm.collectionVariables.set('karyawanToken', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"karyawan@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Modules (Role Based)",
      "item": [
        {
          "name": "HR - Create Module",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{hrToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"judul\": \"Advanced Node.js\",\n  \"deskripsi\": \"Pendalaman Node.js untuk backend engineer\",\n  \"linkMateri\": \"https://example.com/node-advanced\",\n  \"targetSkills\": [\"{{skillId}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/modules",
              "host": ["{{baseUrl}}"],
              "path": ["api", "modules"]
            }
          }
        },
        {
          "name": "HR/Karyawan - Get All Modules",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{karyawanToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/modules",
              "host": ["{{baseUrl}}"],
              "path": ["api", "modules"]
            }
          }
        },
        {
          "name": "HR - Update Module",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{hrToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"judul\": \"Advanced Node.js Updated\",\n  \"deskripsi\": \"Materi terbaru backend engineer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/modules/{{moduleId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "modules", "{{moduleId}}"]
            }
          }
        },
        {
          "name": "HR - Delete Module",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{hrToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/modules/{{moduleId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "modules", "{{moduleId}}"]
            }
          }
        }
